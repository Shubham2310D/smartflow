make_presentation.py
take_screenshots.py
SmartFlow_Presentation.pptx
VIDEO_SCRIPT.md

# Screenshots committed for README preview
# snapshots/

# ── Real-time event store + log lock/temp files (runtime state) ──────────────
data/processed/events.db
*.lock
*.csv.tmp

# ── OSM cache: commit the slim gzip (~5 MB), never the raw ~73 MB dump ────────
data/processed/osm_roads.json
!data/processed/osm_roads.json.gz

# ── Operator-supplied event calendar (external, not part of the repo data) ───
data/external/

